generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ------------------------------------------------------
// BondhuOS AI Command Center - Database Schema
// ------------------------------------------------------

// 1. Customer / Lead Data
model Customer {
  id             String    @id @default(cuid())
  bondhumartId   String?   @unique // ID from the Laravel system
  name           String
  phone          String    @unique
  email          String?
  district       String?
  thana          String?   // Automatically parsed from address
  city           String?
  address        String?
  
  // Dynamic columns
  customData     Json?     // Stores dynamically created columns like Email, specific custom text, etc.
  
  // AI Generated labels & Stats
  label          String?   // e.g., "High Value", "Risky"
  totalOrders    Int       @default(0)
  totalSpent     Float     @default(0.0)
  lastOrderAt    DateTime?
  
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  orders         Order[]
  chatLogs       ChatLog[]
}

// 2. Product Data
model Product {
  id             String    @id @default(cuid())
  bondhumartId   String    @unique // ID from the Laravel system
  name           String
  price          Float
  imageUrl       String?
  category       String?
  stock          Int       @default(0)
  description    String?   @db.Text
  isAdActive     Boolean   @default(false) // Ad tracking
  
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  orders         Order[]
}

// 3. Order Data
model Order {
  id               String    @id @default(cuid())
  bondhumartId     String    @unique // ID from the Laravel system
  customerId       String
  customer         Customer  @relation(fields: [customerId], references: [id])
  productId        String
  product          Product   @relation(fields: [productId], references: [id])
  
  quantity         Int       @default(1)
  amount           Float
  deliveryCharge   Float     @default(0.0)
  
  // Dynamic columns for specific orders
  customData       Json?
  status           String    @default("Pending") // Pending, Delivered, Cancelled, Returned
  cancelledReason  String?
  
  // Courier details
  courierName      String?
  courierTracking  String?
  
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  deliveredAt      DateTime?

  courierBookings  CourierBooking[]
}

// 4. Broadcast History
model Broadcast {
  id             String    @id @default(cuid())
  targetSegment  String    // e.g., "Cancelled last month"
  message        String    @db.Text
  imageUrl       String?
  sentCount      Int       @default(0)
  channel        String    // WhatsApp, Email
  
  createdAt      DateTime  @default(now())
}

// 5. AI Chat Log
model ChatLog {
  id             String    @id @default(cuid())
  customerPhone  String
  customer       Customer? @relation(fields: [customerPhone], references: [phone])
  
  message        String    @db.Text // User message (text/audio converted to text)
  aiResponse     String    @db.Text // AI's reply
  
  createdAt      DateTime  @default(now())
}

// 6. Courier Booking
model CourierBooking {
  id             String    @id @default(cuid())
  orderId        String
  order          Order     @relation(fields: [orderId], references: [id])
  
  courierName    String    // Steadfast, Pathao, RedX
  trackingNo     String?
  status         String    @default("Booked")
  
  bookedAt       DateTime  @default(now())
}

// 7. Knowledge Base
model KnowledgeBase {
  id             String    @id @default(cuid())
  topic          String
  content        String    @db.Text
  
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}
